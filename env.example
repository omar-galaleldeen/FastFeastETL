# ============================================================
# FastFeast Pipeline — Environment Variables
# ============================================================
# Copy this file to .env and fill in your real values.
#   cp .env.example .env
#
# .env is listed in .gitignore and must NEVER be committed.
# These values are injected into pipeline_config.yaml at
# startup by config/config_loader.py.
# ============================================================

# ── Postgres ─────────────────────────────────────────────────
# Password for the postgres user defined in pipeline_config.yaml
PGPASSWORD=your_postgres_password_here

# ── SMTP (Gmail App Password recommended) ────────────────────
# The Gmail address used to send pipeline alert emails
SMTP_USER=your_email@gmail.com

# Gmail App Password (NOT your account password).
# Generate one at: https://myaccount.google.com/apppasswords
SMTP_PASSWORD=your_16_char_app_password_here

# The "From" address shown in alert emails (usually same as SMTP_USER)
SMTP_SENDER=your_email@gmail.com

# The address that receives alert emails
SMTP_RECEIVER=your_email@gmail.com
